# Core auth/session
JWT_SECRET=replace-with-a-long-random-secret
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Database
DATABASE_URL=mysql://user:password@host:3306/wsc

# AI provider
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Live voice / realtime
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=alloy

# Deployment behavior
# Leave false in production. Enable only for demo previews if you intentionally
# want local role sign-in and deterministic AI fallback without external auth/AI.
ALLOW_DEMO_MODE=false
