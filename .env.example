# Core auth/session
JWT_SECRET=replace-with-a-long-random-secret
OWNER_OPEN_ID=

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Use the Transaction pooler connection string from Supabase -> Connect.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-your-region.pooler.supabase.com:6543/postgres
SUPABASE_SESSION_MEDIA_BUCKET=session-media
SUPABASE_POLICY_DOCUMENTS_BUCKET=policy-documents
SUPABASE_GENERATED_ASSETS_BUCKET=generated-assets
SUPABASE_SEED_PASSWORD=WSCTraining123!

# AI provider
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Live voice / realtime
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=alloy
